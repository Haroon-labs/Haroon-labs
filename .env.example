# GitHub fine-grained personal access token
# Create at: https://github.com/settings/tokens?type=beta
# Permissions needed:
#   - read:user
#   - public_repo (for public repos)
#   - repo (for private repos, if included)
PAT_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your birth date (for automatic age calculation in README)
# Format: DD.MM.YYYY
BIRTH_DATE=YOUR_BIRTH_DATE

# Identity & contact info shown in the README card (all optional - each falls back to a generic placeholder if unset)
FULL_NAME=Your Name
CONTACT_EMAIL=you@example.com
LINKEDIN_URL=https://www.linkedin.com/in/your-profile/

# Profile photos (dark/light theme), relative to repo root
PHOTO_LIGHT=white.png
PHOTO_DARK=dark.png

# The "host" part of the neofetch-style "login@host" header in the stats panel
NEOFETCH_HOST=profile

# Info panel content (all optional - each falls back to a sensible default if unset)
INFO_OS=Windows 11, macOS, Linux
INFO_HOST=Your Company GmbH
INFO_KERNEL=Your Job Title
INFO_IDE=VSCode, IDEA, Cursor
INFO_LANGUAGES_PROGRAMMING=Python, Java
INFO_LANGUAGES_REAL=German, English
INFO_HOBBIES_TECHNICAL=LLM Fine-tuning, Software development
INFO_HOBBIES_SPORTS=Fitness, Jogging, Cycling, Swimming
