# GitHub fine-grained personal access token
# Create at: https://github.com/settings/tokens?type=beta
# Permissions needed:
#   - read:user
#   - public_repo (for public repos)
#   - repo (for private repos, if included)
#
# This is the only secret value. It stays local (gitignored) and, for the
# automated workflow, lives as the repository Secret PAT_TOKEN
# (Settings -> Secrets and variables -> Actions -> Secrets tab).
#
# Everything else (name, contact info, photos, info panel content) is
# non-sensitive and lives in profile.env, which is committed to the repo
# and read by both local runs and the GitHub Actions workflow. Edit
# profile.env directly - no .env entry or repository variable needed for it.
PAT_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
